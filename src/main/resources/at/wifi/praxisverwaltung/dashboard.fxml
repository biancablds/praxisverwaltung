<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #FBD6FF;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="at.wifi.praxisverwaltung.DashboardController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="dashboardWelcome" text="Dashboard" textFill="#ff00c3">
      <font>
         <Font name="JetBrains Mono Light" size="36.0" />
      </font></Label>
   <Label fx:id="loginText" layoutX="30.0" layoutY="75.0" text="Bitte geben Sie ihre Daten ein um sich anzumelden." textFill="#480137">
      <font>
         <Font name="JetBrains Mono Light" size="14.0" />
      </font>
   </Label>
</VBox>
